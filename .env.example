# =============================================================================
# Tesis N8N Turnos — Variables de entorno (canonico)
# =============================================================================
# Copiar este archivo a `.env` (en la raiz del repo) y completar con valores
# reales. Las variables secretas (SECRET_KEY, passwords, credenciales Google)
# NUNCA deben commitearse.
#
# Este archivo es la fuente unica de verdad para variables de entorno: el
# backend declara las mismas variables en `backend/app/config.py` y un test
# automatico valida la coherencia entre ambos (ver test_config.py).
# =============================================================================


# -----------------------------------------------------------------------------
# Base de datos
# -----------------------------------------------------------------------------
# URL de conexion a PostgreSQL usando el driver asyncpg. Obligatoria.
# Ejemplo local: postgresql+asyncpg://turnos:turnos@localhost:5432/turnos
# Ejemplo docker: postgresql+asyncpg://turnos:turnos@db:5432/turnos
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/turnos


# -----------------------------------------------------------------------------
# Aplicacion / entorno
# -----------------------------------------------------------------------------
# Entorno de ejecucion: development | test | production. Default: development.
ENV=development

# Clave secreta para firmar JWT. OBLIGATORIA en production. Generar con:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production

# Algoritmo de firma de JWT. Default: HS256.
ALGORITHM=HS256

# Minutos hasta que un access_token expira. Default: 1440 (24h).
ACCESS_TOKEN_EXPIRE_MINUTES=1440


# -----------------------------------------------------------------------------
# Google Calendar
# -----------------------------------------------------------------------------
# Credenciales OAuth2 de Google. Ambas se inyectan como strings vacios en
# desarrollo y se completan en production. Si quedan vacias, la integracion
# con Calendar queda deshabilitada sin romper el arranque.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Reintentos ante errores transitorios en la API de Google Calendar.
GOOGLE_CALENDAR_MAX_RETRIES=3
GOOGLE_CALENDAR_BASE_DELAY=1.0
GOOGLE_CALENDAR_MAX_DELAY=10.0


# -----------------------------------------------------------------------------
# Scheduler / reservas / recordatorios
# -----------------------------------------------------------------------------
# Minutos que una reserva temporal (slot en hold) permanece reservada antes
# de liberarse automaticamente. Default: 10.
RESERVA_TEMPORAL_MINUTOS=10

# Minutos que un turno permanece en lista de espera antes de descartarse.
# Default: 5.
LISTA_ESPERA_MINUTOS=5

# Horas antes del turno en que se envia el recordatorio. Default: 24.
RECORDATORIO_HORAS_ANTES=24

# Periodicidad del job APScheduler de envio de recordatorios (minutos).
# Default: 60.
RECORDATORIO_JOB_INTERVAL_MINUTOS=60

# Periodicidad del job APScheduler de marcado automatico de turnos
# completados (minutos). Default: 5.
COMPLETADO_JOB_INTERVAL_MINUTOS=5


# -----------------------------------------------------------------------------
# Seed / bootstrap
# -----------------------------------------------------------------------------
# Password por defecto del Profesional seed que se crea en la primera
# migracion cuando la tabla esta vacia. Si se deja vacio, el seed no
# asigna password (caso inseguro, solo para tests).
SEED_DEFAULT_PASSWORD=changeme

# Email del SuperAdmin creado en la primera migracion. Si esta vacio, no
# se crea ningun super-admin.
SUPER_ADMIN_EMAIL=

# Password en TEXTO PLANO del SuperAdmin seed. La aplicacion hashea este
# valor internamente con bcrypt antes de persistirlo. NO commitear un
# valor real en este archivo.
SUPER_ADMIN_PASSWORD=
