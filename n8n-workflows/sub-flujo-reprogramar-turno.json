    {
      "id": "e1b2c3d4-0001-4000-8000-000000000008",
      "name": "Code - Formatear Slots",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1160, 420],
      "parameters": {
        "mode": "runOnceForAll",
        "language": "javaScript",
        "jsCode": "const input = ($input.all()[0] && $input.all()[0].json) || {};\nconst chatId = input.chat_id;\nconst turnoId = input.turno_id;\nconst nuevaFecha = input.nueva_fecha || '';\n\nlet slots = [];\nif (Array.isArray(input)) {\n  slots = input;\n} else if (Array.isArray(input.slots)) {\n  slots = input.slots;\n}\n\nconst disponibles = slots.filter(function (s) { return s.disponible !== false; });\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    turno_id: turnoId,\n    nueva_fecha: nuevaFecha,\n    slots: disponibles,\n    cantidad: disponibles.length\n  }\n}];"
      }
    },
    {
      "id": "e1b2c3d4-0001-4000-8000-000000000009",
      "name": "Telegram - Pedir Slot",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1400, 420],
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{ $json.chat_id }}",
        "text": "={{ 'Elegí el nuevo horario para el ' + $json.nueva_fecha + ':' }}",
        "options": {
          "reply_markup": {
            "inline_keyboard": "={{ $json.slots.length > 0 ? $json.slots.map(function(s) { return [{ text: s.hora_inicio + (s.hora_fin ? (' - ' + s.hora_fin) : ''), callback_data: 'cmd:reprogramar:turno_id:' + $json.turno_id + ':fecha:' + $json.nueva_fecha + ':slot:' + s.hora_inicio }]; }) : [[{ text: 'No hay horarios', callback_data: 'cmd:reprogramar:turno_id:' + $json.turno_id + ':fecha:' + $json.nueva_fecha + ':slot:none' }]] }}"
          }
        }
