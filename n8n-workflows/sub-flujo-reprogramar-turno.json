        "chatId": "={{ $json.chat_id }}",
        "text": "Para reprogramar un turno necesito que me pases el ID. Escribí el comando así:\n\n/reprogramar <ID>\n\nPor ejemplo: /reprogramar 42",
        "additionalFields": {}
