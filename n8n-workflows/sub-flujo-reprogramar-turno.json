        "chatId": "={{ $json.chat_id }}",
        "text": "={{ 'Reprogramando turno #' + $json.turno_id + '. Elegí la nueva fecha:' }}",
        "options": {
          "reply_markup": {
            "inline_keyboard": "={{ $json.fechas_etiquetadas.map(function(f) { return [{ text: f.label, callback_data: 'cmd:reprogramar:turno_id:' + $json.turno_id + ':fecha:' + f.fecha }]; }) }}"
          }
