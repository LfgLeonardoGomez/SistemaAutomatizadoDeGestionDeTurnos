          "properties": {
            "genericAuthType": "httpHeaderAuth"
          }
        }
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "profesional-api-key",
          "name": "Profesional API Key"
        }
      }
    },
    {
      "id": "e1b2c3d4-0001-4000-8000-000000000009",
      "name": "Telegram - Confirmar Reprogramaci\u00f3n",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [2000, 320],
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{ $json.chat_id }}",
        "text": "=\u2705 Turno #{{ $('Code - Extraer Turno ID').item.json.turno_id }} reprogramado!\n\nNueva fecha: {{ $json.nueva_fecha || $json.fecha }}\nNueva hora: {{ $json.nueva_hora_inicio || $json.hora_inicio }}\n\nTe enviaremos un recordatorio un d\u00eda antes. \ud83d\ude4f",
        "additionalFields": {}
      },
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot-credentials",
          "name": "Telegram Bot Credentials"
        }
      }
    }
