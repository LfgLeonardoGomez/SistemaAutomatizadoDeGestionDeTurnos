    {
      "id": "e1b2c3d4-0001-4000-8000-000000000011",
      "name": "Code - Formatear Resultado",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1160, 600],
      "parameters": {
        "mode": "runOnceForAll",
        "language": "javaScript",
        "jsCode": "const input = ($input.all()[0] && $input.all()[0].json) || {};\nconst chatId = input.chat_id;\nconst turnoId = input.turno_id;\nconst nuevaFecha = input.fecha || input.nueva_fecha;\nconst nuevoSlot = input.hora_inicio || input.nuevo_slot;\nconst errorStatus = input.statusCode && input.statusCode >= 400;\nconst errorDetail = input.detail || (errorStatus ? 'Error HTTP ' + input.statusCode : null);\n\nlet mensaje = '';\nlet exito = false;\nif (errorStatus) {\n  if (input.statusCode === 404) {\n    mensaje = 'Turno no encontrado.';\n  } else if (input.statusCode === 409) {\n    mensaje = 'No se puede reprogramar el turno en su estado actual o el horario ya está ocupado.';\n  } else {\n    mensaje = 'Error al reprogramar: ' + (input.detail || ('HTTP ' + input.statusCode));\n  }\n  exito = false;\n} else {\n  mensaje = 'Turno #' + turnoId + ' reprogramado.\\n\\nNueva fecha: ' + nuevaFecha + '\\nNueva hora: ' + nuevoSlot + '\\n\\nTe enviaremos un recordatorio el día anterior.';\n  exito = true;\n}\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    turno_id: turnoId,\n    nueva_fecha: nuevaFecha,\n    nuevo_slot: nuevoSlot,\n    exito: exito,\n    mensaje: mensaje\n  }\n}];"
      }
    },
