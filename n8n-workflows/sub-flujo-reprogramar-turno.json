    {
      "id": "e1b2c3d4-0001-4000-8000-000000000005",
      "name": "Code - Formatear Fechas",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 240],
      "parameters": {
        "mode": "runOnceForAll",
        "language": "javaScript",
        "jsCode": "const input = ($input.all()[0] && $input.all()[0].json) || {};\nconst chatId = input.chat_id;\nconst turnoId = input.turno_id;\nconst fechas = input.fechas_disponibles || [];\n\nconst nombresCorto = {\n  '0': 'Hoy',\n  '1': 'Mañana',\n  '2': 'Pasado mañana'\n};\n\nconst diasCortos = ['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'];\nconst mesesCortos = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];\n\nconst etiquetas = fechas.map(function (f, i) {\n  const d = new Date(f + 'T00:00:00');\n  const dow = diasCortos[d.getDay()];\n  const day = d.getDate();\n  const mon = mesesCortos[d.getMonth()];\n  const corto = nombresCorto[String(i)] || (dow + ' ' + day + ' ' + mon);\n  return { fecha: f, label: corto + ' (' + f + ')' };\n});\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    turno_id: turnoId,\n    fechas_etiquetadas: etiquetas\n  }\n}];"
      }
    },
    {
      "id": "e1b2c3d4-0001-4000-8000-000000000006",
      "name": "Telegram - Pedir Fecha",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1160, 240],
      "parameters": {
