      "name": "Code - Decidir Paso",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 320],
      "parameters": {
        "mode": "runOnceForAll",
        "language": "javaScript",
        "jsCode": "const input = ($input.all()[0] && $input.all()[0].json) || {};\nconst chatId = input.chat_id;\nconst comando = input.comando || 'reprogramar';\nconst payload = input.payload || {};\nconst text = String(input.text || '');\n\nlet turnoId = payload.turno_id || '';\nlet nuevaFecha = payload.nueva_fecha || payload.fecha || '';\nlet nuevoSlot = payload.nuevo_slot || payload.slot || '';\n\nconst fechaSlotMatch = text.match(/^cmd:reprogramar:turno_id:(\\d+):fecha:([^:]+):slot:(.+)$/);\nconst fechaOnlyMatch = text.match(/^cmd:reprogramar:turno_id:(\\d+):fecha:([^:]+)$/);\nconst idMatch = text.match(/^cmd:reprogramar:turno_id:(\\d+)$/);\nconst simpleIdMatch = text.match(/^reprogramar:(\\d+)$/);\n\nif (fechaSlotMatch) {\n  turnoId = fechaSlotMatch[1];\n  nuevaFecha = fechaSlotMatch[2];\n  nuevoSlot = fechaSlotMatch[3];\n} else if (fechaOnlyMatch) {\n  turnoId = fechaOnlyMatch[1];\n  nuevaFecha = fechaOnlyMatch[2];\n} else if (idMatch) {\n  turnoId = idMatch[1];\n} else if (simpleIdMatch) {\n  turnoId = simpleIdMatch[1];\n}\n\nconst fechas = [];\nconst today = new Date();\nfor (let i = 1; i <= 7; i++) {\n  const d = new Date(today);\n  d.setDate(d.getDate() + i);\n  fechas.push(d.toISOString().slice(0, 10));\n}\n\nlet accion;\nif (!turnoId) {\n  accion = 'pedir_id';\n} else if (!nuevaFecha) {\n  accion = 'pedir_fecha';\n} else if (!nuevoSlot) {\n  accion = 'pedir_slot';\n} else {\n  accion = 'ejecutar';\n}\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    comando: comando,\n    accion: accion,\n    turno_id: turnoId,\n    nueva_fecha: nuevaFecha,\n    nuevo_slot: nuevoSlot,\n    fechas_disponibles: fechas\n  }\n}];"
      }
