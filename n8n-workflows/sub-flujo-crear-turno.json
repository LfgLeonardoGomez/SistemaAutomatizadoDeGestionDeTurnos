          "name": "Profesional API Key"
        }
      }
    },
    {
      "id": "c1b2c3d4-0001-4000-8000-000000000006",
      "name": "Code - Formatear Slots",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 320],
      "parameters": {
        "mode": "runOnceForAll",
        "language": "javaScript",
        "jsCode": "const input = ($input.all()[0] && $input.all()[0].json) || {};\nconst fecha = input.fecha || ($('Code - Parsear Fecha').item && $('Code - Parsear Fecha').item.json && $('Code - Parsear Fecha').item.json.fecha);\nconst slots = Array.isArray(input) ? input : (input.slots || input || []);\n\nconst slotsList = Array.isArray(slots) ? slots : (Array.isArray(input.slots) ? input.slots : []);\n\nif (slotsList.length === 0) {\n  return [{\n    json: {\n      chat_id: input.chat_id,\n      fecha: fecha,\n      slots: [],\n      empty: true,\n      message: 'No hay horarios disponibles para esa fecha.'\n    }\n  }];\n}\n\nconst buttons = slotsList\n  .filter(function (s) { return s.disponible !== false; })\n  .map(function (s) {\n    const hora = s.hora_inicio || s.hora;\n    return { label: hora + (s.hora_fin ? (' - ' + s.hora_fin) : ''), value: 'hora:' + hora };\n  });\n\nreturn [{\n  json: {\n    chat_id: input.chat_id,\n    fecha: fecha,\n    slots: slotsList,\n    empty: false,\n    buttons: buttons\n  }\n}];"
      }
    },
