    {
      "id": "c1b2c3d4-0001-4000-8000-000000000012",
      "name": "Code - Parsear CSV",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2660, 320],
      "parameters": {
        "mode": "runOnceForAll",
        "language": "javaScript",
        "jsCode": "const input = ($input.all()[0] && $input.all()[0].json) || {};\nconst messageText = (input.data && input.data.message && input.data.message.text) || '';\n\nconst csv = String(messageText).trim();\nconst parts = csv.split(',').map(function (p) { return p.trim(); });\nconst nombre = parts[0] || '';\nconst apellido = parts[1] || '';\nconst dni = parts[2] || '';\nconst telefono = parts[3] || '';\n\nconst chatId = input.chat_id;\nconst turnoId = input.id || (input.turno_id) || ($('HTTP Request - POST Reserva').item && $('HTTP Request - POST Reserva').item.json && $('HTTP Request - POST Reserva').item.json.id);\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    turno_id: turnoId,\n    nombre: nombre,\n    apellido: apellido,\n    dni: dni,\n    telefono: telefono\n  }\n}];"
      }
