      "parameters": {
        "mode": "runOnceForAll",
        "language": "javaScript",
        "jsCode": "const input = ($input.all()[0] && $input.all()[0].json) || {};\nconst callbackData = (input.data && input.data.callback_query && input.data.callback_query.data) || '';\nconst hora_inicio = String(callbackData).split(':')[1] || '';\nconst fecha = input.fecha || ($('Code - Parsear Fecha').item && $('Code - Parsear Fecha').item.json && $('Code - Parsear Fecha').item.json.fecha);\nconst chatId = input.chat_id;\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    fecha: fecha,\n    hora_inicio: hora_inicio,\n    callback_query_id: input.data && input.data.callback_query && input.data.callback_query.id\n  }\n}];"
