      "name": "HTTP Request - GET Disponibilidad",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1120, 320],
      "parameters": {
        "method": "GET",
        "url": "={{ $env.BACKEND_URL }}/turnos/disponibles?fecha={{ $json.fecha }}",
