    {
      "id": "c1b2c3d4-0001-4000-8000-000000000002",
      "name": "Code - Generar Fechas",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 320],
      "parameters": {
        "mode": "runOnceForAll",
        "language": "javaScript",
        "jsCode": "const input = ($input.all()[0] && $input.all()[0].json) || {};\nconst chatId = input.chat_id;\n\nconst fechas = [];\nconst today = new Date();\nfor (let i = 1; i <= 7; i++) {\n  const d = new Date(today);\n  d.setDate(d.getDate() + i);\n  fechas.push(d.toISOString().slice(0, 10));\n}\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    comando: input.comando,\n    payload: input.payload,\n    fechas_disponibles: fechas\n  }\n}];"
      }
    },
    {
      "id": "c1b2c3d4-0001-4000-8000-000000000003",
      "name": "Telegram - Pedir Fecha",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [680, 320],
      "parameters": {
        "operation": "sendAndWait",
        "chatId": "={{ $json.chat_id }}",
        "message": "=Seleccion\u00e1 una fecha para tu turno:",
        "options": {
          "buttons": {
            "values": "={{ $json.fechas_disponibles.map(f => ({ label: f, value: 'fecha:' + f })) }}"
          }
        }
      },
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot-credentials",
          "name": "Telegram Bot Credentials"
        }
      }
    },
    {
      "id": "c1b2c3d4-0001-4000-8000-000000000004",
      "name": "Code - Parsear Fecha",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 320],
      "parameters": {
        "mode": "runOnceForAll",
        "language": "javaScript",
        "jsCode": "const input = ($input.all()[0] && $input.all()[0].json) || {};\nconst callbackData = (input.data && input.data.callback_query && input.data.callback_query.data) || '';\nconst fecha = String(callbackData).split(':')[1] || '';\n\nreturn [{\n  json: {\n    chat_id: input.chat_id,\n    fecha: fecha,\n    callback_query_id: input.data && input.data.callback_query && input.data.callback_query.id\n  }\n}];"
      }
    },
