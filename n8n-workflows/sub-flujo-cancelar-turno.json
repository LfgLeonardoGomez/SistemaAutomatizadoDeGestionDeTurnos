    {
      "id": "d1b2c3d4-0001-4000-8000-000000000002",
      "name": "Code - Decidir Paso",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 320],
      "parameters": {
        "mode": "runOnceForAll",
        "language": "javaScript",
        "jsCode": "const input = ($input.all()[0] && $input.all()[0].json) || {};\nconst chatId = input.chat_id;\nconst comando = input.comando || 'cancelar';\nconst payload = input.payload || {};\nconst text = String(input.text || '');\n\nlet turnoId = payload.turno_id || '';\n\nif (text.startsWith('cmd:cancelar:turno_id:')) {\n  turnoId = text.substring('cmd:cancelar:turno_id:'.length);\n} else if (text.startsWith('cancelar:') && text.indexOf(':') === text.lastIndexOf(':')) {\n  const candidate = text.substring('cancelar:'.length).trim();\n  if (/^\\d+$/.test(candidate)) {\n    turnoId = candidate;\n  }\n}\n\nconst accion = turnoId ? 'cancelar' : 'pedir_id';\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    comando: comando,\n    accion: accion,\n    turno_id: turnoId\n  }\n}];"
      }
    },
    {
