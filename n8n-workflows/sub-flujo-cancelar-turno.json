      "typeVersion": 1.2,
      "position": [920, 120],
      "parameters": {
        "operation": "sendMessage",
        "chatId": "={{ $json.chat_id }}",
        "text": "Para cancelar un turno necesito que me pases el ID. Escribí el comando así:\n\n/cancelar <ID>\n\nPor ejemplo: /cancelar 42\n\nSi no sabés el ID, escribí /reservar para crear uno nuevo o contactanos.",
