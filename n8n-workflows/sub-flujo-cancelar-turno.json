        }
      }
    },
    {
      "id": "d1b2c3d4-0001-4000-8000-000000000006",
      "name": "Code - Formatear Respuesta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1160, 320],
      "parameters": {
        "mode": "runOnceForAll",
        "language": "javaScript",
        "jsCode": "const input = ($input.all()[0] && $input.all()[0].json) || {};\nconst chatId = input.chat_id;\nconst turnoId = input.turno_id;\nconst errorStatus = input.statusCode && input.statusCode >= 400;\nconst errorDetail = input.detail || (errorStatus ? 'Error HTTP ' + input.statusCode : null);\n\nlet mensaje = '';\nlet exito = false;\nif (errorStatus) {\n  if (input.statusCode === 404) {\n    mensaje = 'Turno no encontrado. Verificá el ID y probá de nuevo.';\n  } else if (input.statusCode === 409) {\n    mensaje = 'El turno ya fue cancelado previamente o no se puede cancelar en su estado actual.';\n  } else {\n    mensaje = 'Error al cancelar el turno: ' + (input.detail || ('HTTP ' + input.statusCode));\n  }\n  exito = false;\n} else {\n  mensaje = 'Turno #' + turnoId + ' cancelado exitosamente.';\n  exito = true;\n}\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    turno_id: turnoId,\n    exito: exito,\n    mensaje: mensaje\n  }\n}];"
      }
    },
    {
      "id": "d1b2c3d4-0001-4000-8000-000000000007",
      "name": "Telegram - Cancelar Confirmado",
      "type": "n8n-nodes-base.telegram",
