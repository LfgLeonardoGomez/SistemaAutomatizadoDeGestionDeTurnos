        "chatId": "={{ $json.chat_id }}",
        "text": "={{ $json.mensaje }}",
        "options": {
          "reply_markup": {
            "inline_keyboard": "={{ $json.exito ? [[{ text: 'Reprogramar este turno', callback_data: 'cmd:reprogramar:turno_id:' + $json.turno_id }], [{ text: 'Volver al menú', callback_data: 'cmd:menu' }]] : [[{ text: 'Volver a intentar', callback_data: 'cmd:cancelar' }]] }}"
          }
        }
      },
